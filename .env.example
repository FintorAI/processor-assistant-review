# --- TEST ENVIRONMENT (Concept API - Client Credentials) ---
ENCOMPASS_API_BASE_URL=https://concept.api.elliemae.com
ENCOMPASS_CLIENT_ID=
ENCOMPASS_CLIENT_SECRET=
ENCOMPASS_INSTANCE_ID=
# No ENCOMPASS_USERNAME or ENCOMPASS_PASSWORD needed for test env

# =============================================================================

# LandingAI Configuration (for document extraction)
LANDINGAI_API_KEY=

# DocRepo S3 Storage Configuration
DOCREPO_AUTH_TOKEN=
DOCREPO_PUT_API_BASE=
DOCREPO_GET_API_BASE=
DOCREPO_CREATE_API_BASE=

# Development Mode Configuration
# Set to "true" to use local development version of copilotagent
# Set to "false" (or omit) to use PyPI version
USE_LOCAL_COPILOTAGENT=false

# AI Debug Mode
# Set to "true" to see detailed AI model responses in logs
# Set to "false" (or omit) for normal logging
AI_DEBUG_MODE=false

# USPS Client Secrets
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=

# LLM Secrets
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Amazon Textract OCR
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-1

# LangGraph / LangSmith
LANGGRAPH_API_KEY=
LANGGRAPH_TOKEN=
LANGSMITH_API_KEY=
LANGCHAIN_API_KEY=

# eFolder
EFOLDER_API_TOKEN=

# Agent settings
LANGGRAPH_DEFAULT_RECURSION_LIMIT=100000
