{
  "agent": {
    "name": "ProcessorAgent",
    "version": "1.0.0",
    "model": "claude-sonnet-4-6"
  },
  "loan_profile_fields": {
    "loan_type": {
      "source_field": "1172",
      "values": [
        "Conventional",
        "FHA",
        "VA",
        "USDA"
      ]
    },
    "purpose": {
      "source_field": "19",
      "values": [
        "Purchase",
        "Refinance",
        "CashOutRefi"
      ]
    },
    "state": {
      "source_field": "14",
      "values": "2-letter state code"
    },
    "trust": {
      "source_field": "CX.CLOSE.TRUST",
      "values": [
        true,
        false
      ]
    },
    "note_llc": {
      "source_field": "LO/processor email",
      "values": [
        true,
        false
      ]
    }
  },
  "rule_modifier_stats": {
    "total_modifiers": 3,
    "by_field": {
      "state": 1,
      "loan_type": 2
    }
  },
