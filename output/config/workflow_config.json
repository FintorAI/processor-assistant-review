              "condition": {
                "field": "loan_type",
                "equals": "FHA"
              },
              "action": "add",
              "description": "FHA requires only 1 month of bank statements (vs 2 for Conventional).",
              "source": "notes.txt:64"
            }
          ]
        },
        "2": {
          "name": "EMD Check (3b)",
          "tools": [
            "review_urla_emd"
          ]
        },
        "3": {
