    "STEP_00": {
      "name": "Data Gathering",
      "phase": "VERIFICATION",
      "plan_file": "data_gathering.md",
      "tools": [
        "build_loan_summary",
        "extract_almas_images",
        "fetch_doc_fields",
        "fetch_los_fields",
        "find_loan"
      ],
      "substeps": {
        "1": {
          "name": "Find Loan",
          "tools": [
            "find_loan"
          ]
        },
        "2": {
          "name": "Fetch LOS Fields (296 fields)",
          "tools": [
            "fetch_los_fields"
          ]
        },
        "3": {
          "name": "Fetch Doc Fields (34 document types)",
          "tools": [
            "fetch_doc_fields"
          ]
        },
        "4": {
          "name": "Build Loan Summary (URLA)",
          "tools": [
            "build_loan_summary"
          ]
        },
        "6": {
          "name": "Extract Almas-Notes Images (Vision OCR)",
          "tools": [
            "extract_almas_images"
          ]
        }
      }
    },
    "STEP_01": {
      "name": "Pre-Checks",
      "phase": "INTAKE",
      "plan_file": "pre_checks.md",
      "tools": [
        "review_file_contacts",
        "review_property_listing",
        "run_pre_checks"
      ],
      "substeps": {
        "1": {
          "name": "Document Presence Check",
          "tools": [
            "run_pre_checks"
          ],
          "rule_modifiers": [
            {
              "condition": {
                "field": "state",
                "equals": "MD"
              },
              "action": "add",
              "description": "Maryland requires the \"Notice Regarding Right for Assumption Under Certain Circumstances\" disclosure. Flag if missing.\n",
              "source": "notes.txt:14"
            }
          ]
        },
        "2": {
          "name": "File Contacts Check",
          "tools": [
            "review_file_contacts"
          ]
        },
        "3": {
          "name": "Property Verification (Address + Listing / PUD)",
          "tools": [
            "review_property_listing"
          ]
        }
      }
    },
    "STEP_02": {
      "name": "Borrower Summary - Origination",
      "phase": "DATA_REVIEW",
      "plan_file": "borrower_summary___origination.md",
      "tools": [
        "review_borrower_summary"
      ],
      "substeps": {
        "1": {
          "name": "Review Borrower Summary - Origination",
          "tools": [
            "review_borrower_summary"
          ]
        }
