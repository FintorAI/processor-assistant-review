      "plan_file": "1003_urla_page_2.md",
      "tools": [
        "review_urla_employment",
        "review_urla_other_income"
      ],
      "substeps": {
        "1": {
          "name": "Employment Verification (2b VOE)",
          "tools": [
            "review_urla_employment"
          ],
          "rule_modifiers": [
            {
              "condition": {
                "field": "loan_type",
                "equals": "FHA"
              },
              "action": "add",
              "description": "FHA: if employment gap < 6 months, require written explanation from borrower. If gap > 6 months, require 2-year history before the gap.\n",
              "source": "notes.txt:44-48"
            }
          ]
        },
        "2": {
          "name": "Other Income (2e)",
          "tools": [
            "review_urla_other_income"
          ]
        }
      }
    },
