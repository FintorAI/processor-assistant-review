import json
import logging
from datetime import datetime, timezone
from typing import Annotated, Optional

from langchain_core.messages import ToolMessage
from langchain_core.tools import InjectedToolCallId, tool
from langgraph.prebuilt import InjectedState
from langgraph.types import Command

logger = logging.getLogger(__name__)


# ── Helper: get field values from state ──

def _los(state: dict, key: str, default=None):
    """Get a LOS field value from state."""
    entry = state.get("los_fields", {}).get(key, {})
    return entry.get("value", default) if isinstance(entry, dict) else default


def _doc(state: dict, key: str, default=None):
    """Get a doc field value from state."""
    entry = state.get("doc_fields", {}).get(key, {})
    return entry.get("value", default) if isinstance(entry, dict) else default

{% for substep in step.substeps %}

# ═══════════════════════════════════════════════════════════════════════
# Substep {{ substep.id }} — {{ substep.name }}
# ═══════════════════════════════════════════════════════════════════════

@tool
def {{ substep.tool }}(
    tool_call_id: Annotated[str, InjectedToolCallId],
    state: Annotated[dict, InjectedState],
{%- for param in substep.custom_params %}
    {{ param.name }}: {{ param.get('type', 'Optional[str]') }} = {{ param.get('default', 'None') }},
{%- endfor %}
) -> Command:
    """{{ substep.description or substep.name }}

    Call this tool during {{ step.id }} ({{ step.name }}) as substep {{ substep.id }}.
{%- if substep.los_fields_read %}
    Reads LOS: {{ substep.los_fields_read | map(attribute='key') | join(', ') }}
{%- endif %}
{%- if substep.doc_types %}
    Reads Docs: {% for dt in substep.doc_types %}{{ dt.document_type }}{% if dt.all_copies %} (all copies){% endif %}{% if not loop.last %}, {% endif %}{% endfor %}
{%- endif %}
{%- if substep.flags %}
    Flags: {% for fl in substep.flags %}{{ fl.title }} ({{ fl.severity }}){% if not loop.last %}, {% endif %}{% endfor %}
{%- endif %}
{%- if substep.field_updates %}
    Writes: field corrections for {% for u in substep.field_updates %}{{ u.field_id }}{% if not loop.last %}, {% endif %}{% endfor %}
{%- endif %}
    """
    loan_id = state.get("loan_id")
    if not loan_id:
        return Command(update={"messages": [ToolMessage(
            content=json.dumps({"error": "No loan_id in state. Run find_loan first."}),
            tool_call_id=tool_call_id,
        )]})

    logger.info(f"[{{ substep.tool | upper }}] Starting for loan {str(loan_id)[:8]}...")

    flags = []
{% if substep.los_fields_read %}
    # ── Read LOS Fields ──
{%- for f in substep.los_fields_read %}
    {{ f.key }} = _los(state, "{{ f.key }}")  # Field {{ f.field_id }}: {{ f.field_name }}
{%- endfor %}
{% endif %}
{% if substep.doc_types %}
    # ── Read Doc Fields ──
{%- for dt in substep.doc_types %}
    # From: {{ dt.document_type }}{% if dt.all_copies %} (ALL COPIES){% endif %}
{%- for f in dt.fields %}
    {{ f.key }}_doc = _doc(state, "{{ f.key }}")
{%- endfor %}
{%- endfor %}
{% endif %}
{% for rule in substep.rules %}
    # ── Rule: {{ rule.name }} ──
    # {{ rule.logic | replace('\n', '\n    # ') }}
    # Type: {{ rule.type }}
{%- if rule.check %}
    # Check: {{ rule.check }}
{%- endif %}
    # TODO: Implement this rule
    pass

{% endfor %}
{% for flag in substep.flags %}
    # ── Flag: {{ flag.title }} ──
    # Condition: {{ flag.condition }}
    # Severity: {{ flag.severity }}
    # TODO: Add condition check
    # if <condition>:
    #     flags.append({
    #         "substep": "{{ substep.id }}",
    #         "title": "{{ flag.title }}",
    #         "severity": "{{ flag.severity }}",
    #         "details": "",
    #         "suggestion": "{{ flag.suggestion }}",
    #         "resolved": False,
    #         "timestamp": datetime.now(timezone.utc).isoformat(),
    #     })

{% endfor %}
{%- if substep.subagent %}
    # ── Subagent Call: {{ substep.subagent.type }} ──
    # Inputs: {{ substep.subagent.inputs }}
    # Expected: {{ substep.subagent.expected }}
    # TODO: Invoke subagent via task() tool
    # The agent should call: task(subagent_type="{{ substep.subagent.type }}", inputs={...})
    pass

{% endif %}
{%- if substep.field_updates %}
    # ── Field Updates ──
    field_updates = {}
{%- for upd in substep.field_updates %}
    # Field {{ upd.field_id }}: {{ upd.value }} (condition: {{ upd.condition }})
    # TODO: Set value
    # field_updates["{{ upd.field_id }}"] = <computed_value>
{%- endfor %}

    if field_updates:
        try:
            from shared.encompass_io import write_fields
            write_fields(loan_id, field_updates, state=state)
            logger.info(f"[{{ substep.tool | upper }}] Wrote {len(field_updates)} field updates")
        except Exception as e:
            logger.error(f"[{{ substep.tool | upper }}] Field write error: {e}")
            flags.append({
                "substep": "{{ substep.id }}",
                "title": "Field Write Error",
                "severity": "warning",
                "details": str(e),
                "suggestion": "Retry or escalate",
                "resolved": False,
                "timestamp": datetime.now(timezone.utc).isoformat(),
            })
{% endif %}

    # ── Build result ──
    result = {
        "success": True,
        "substep": "{{ substep.id }}",
        "tool": "{{ substep.tool }}",
        "flags_count": len(flags),
        "message": "{{ substep.name }} completed" + (f" with {len(flags)} flags" if flags else ""),
    }

    logger.info(f"[{{ substep.tool | upper }}] {result['message']}")

    update = {
        "messages": [ToolMessage(content=json.dumps(result), tool_call_id=tool_call_id)],
    }
    if flags:
        update["flags"] = flags

    return Command(update=update)
{% endfor %}
